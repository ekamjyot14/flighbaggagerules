---
import Layout from '../layouts/Layout.astro';
import { buildTitle } from '../utils/seo';
---

<Layout
  title={buildTitle('Server Error')}
  description="Something went wrong on our end. Please try again later."
  noindex={true}
>
  <div class="container-page py-32 text-center">
    <p class="text-display-xl mb-4" style="color:var(--color-hairline);font-family:var(--font-mono)">500</p>
    <h1 class="text-display-lg mb-4" style="color:var(--color-ink)">Something Went Wrong</h1>
    <p class="text-body-sm mb-10 mx-auto" style="color:var(--color-mute);max-width:40ch">
      We're experiencing a server error. Please try again in a few moments.
    </p>
    <div class="flex items-center justify-center gap-4">
      <a href="/" class="btn-primary-lg">Go Home</a>
      <button onclick="location.reload()" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium border transition-colors duration-150" style="border-color:var(--color-hairline);color:var(--color-ink);background:var(--color-canvas)">
        Try Again
      </button>
    </div>
  </div>
</Layout>
