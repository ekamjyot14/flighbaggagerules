---
import Layout from '../../layouts/Layout.astro';
import AirlineCard from '../../components/airline/AirlineCard.astro';
import { getCollection } from 'astro:content';
import { getLocaleFromUrl, createTranslator, loadTranslations, getSegmentPath, getHreflangs } from '../../i18n/utils';
import { buildTitle } from '../../utils/seo';
import type { Locale } from '../../i18n/config';

const locale = getLocaleFromUrl(Astro.url) as Locale;
const translations = await loadTranslations(locale);
const t = createTranslator(translations);

const airlines = await getCollection('airlines');
const sorted = airlines.sort((a, b) => a.data.name.localeCompare(b.data.name));

const site = 'https://flightbaggagerules.com';
const hreflangAlternates = getHreflangs(site, '/airlines', locale);

// Get unique regions and alliances for filters
const regions = [...new Set(sorted.map((a) => a.data.region).filter(Boolean))].sort();
const alliances = [...new Set(sorted.map((a) => a.data.alliance).filter((a) => a && a !== 'none'))].sort();
---

<Layout
  title={buildTitle(t('seo.airlines.title'))}
  description={t('seo.airlines.description')}
  locale={locale}
  hreflangAlternates={hreflangAlternates}
>
  <div class="container-page py-12">
    <!-- Page header -->
    <div class="mb-8">
      <h1 class="text-display-lg mb-3" style="color:var(--color-ink)">{t('airlines.title')}</h1>
      <p class="text-body-sm" style="color:var(--color-mute)">{t('airlines.subtitle')}</p>
    </div>

    <!-- Filters & Controls -->
    <div class="flex flex-wrap items-center gap-3 mb-8 p-4 rounded-xl border" style="background:var(--color-canvas-soft);border-color:var(--color-hairline)">
      <!-- Search -->
      <div class="relative flex-1 min-w-[200px]">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 pointer-events-none" style="color:var(--color-mute)" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="6.5" cy="6.5" r="4.5"/><path d="M10.5 10.5L14 14"/>
        </svg>
        <input
          id="airline-search"
          type="text"
          placeholder="Search airlines..."
          class="w-full pl-9 pr-3 h-9 rounded-lg border text-sm outline-none transition-colors"
          style="background:var(--color-canvas);border-color:var(--color-hairline);color:var(--color-ink)"
        />
      </div>

      <!-- Region filter -->
      <select id="region-filter" class="h-9 px-3 rounded-lg border text-sm cursor-pointer" style="background:var(--color-canvas);border-color:var(--color-hairline);color:var(--color-ink)">
        <option value="">All Regions</option>
        {regions.map((r) => <option value={r}>{r}</option>)}
      </select>

      <!-- Alliance filter -->
      <select id="alliance-filter" class="h-9 px-3 rounded-lg border text-sm cursor-pointer" style="background:var(--color-canvas);border-color:var(--color-hairline);color:var(--color-ink)">
        <option value="">All Alliances</option>
        {alliances.map((a) => <option value={a}>{a}</option>)}
      </select>

      <!-- Per page -->
      <select id="per-page" class="h-9 px-3 rounded-lg border text-sm cursor-pointer" style="background:var(--color-canvas);border-color:var(--color-hairline);color:var(--color-ink)">
        <option value="12">12 per page</option>
        <option value="24">24 per page</option>
        <option value="48">48 per page</option>
        <option value="all">Show all</option>
      </select>
    </div>

    <!-- Results count -->
    <p id="results-count" class="text-xs mb-4 font-medium" style="color:var(--color-mute)"></p>

    <!-- Airline grid -->
    <div id="airline-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4" role="list">
      {sorted.map((airline) => (
        <div
          role="listitem"
          class="airline-card"
          data-name={airline.data.name.toLowerCase()}
          data-region={airline.data.region || ''}
          data-alliance={airline.data.alliance || ''}
          data-country={airline.data.country.toLowerCase()}
        >
          <AirlineCard
            name={airline.data.name}
            slug={airline.data.slug}
            iata={airline.data.iata}
            country={airline.data.country}
            region={airline.data.region}
            alliance={airline.data.alliance}
            logo={airline.data.logo}
            lastUpdated={airline.data.lastUpdated}
            href={getSegmentPath(locale, 'airlines', airline.data.slug)}
          />
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden py-16 text-center">
      <p class="text-body-sm" style="color:var(--color-mute)">No airlines match your filters.</p>
    </div>

    <!-- Pagination -->
    <div id="pagination" class="flex items-center justify-center gap-2 mt-8 pt-6 border-t" style="border-color:var(--color-hairline)">
    </div>
  </div>
</Layout>

<script>
  function initAirlineFilters() {
    const searchInput = document.getElementById('airline-search') as HTMLInputElement;
    const regionFilter = document.getElementById('region-filter') as HTMLSelectElement;
    const allianceFilter = document.getElementById('alliance-filter') as HTMLSelectElement;
    const perPage = document.getElementById('per-page') as HTMLSelectElement;
    const grid = document.getElementById('airline-grid')!;
    const pagination = document.getElementById('pagination')!;
    const resultsCount = document.getElementById('results-count')!;
    const emptyState = document.getElementById('empty-state')!;
    const cards = Array.from(grid.querySelectorAll('.airline-card')) as HTMLElement[];

    let currentPage = 1;

    function getFilteredCards(): HTMLElement[] {
      const search = searchInput.value.toLowerCase().trim();
      const region = regionFilter.value;
      const alliance = allianceFilter.value;

      return cards.filter((card) => {
        const name = card.dataset.name || '';
        const country = card.dataset.country || '';
        const cardRegion = card.dataset.region || '';
        const cardAlliance = card.dataset.alliance || '';

        const matchesSearch = !search || name.includes(search) || country.includes(search);
        const matchesRegion = !region || cardRegion === region;
        const matchesAlliance = !alliance || cardAlliance === alliance;

        return matchesSearch && matchesRegion && matchesAlliance;
      });
    }

    function render() {
      const filtered = getFilteredCards();
      const limit = perPage.value === 'all' ? filtered.length : parseInt(perPage.value);
      const totalPages = Math.ceil(filtered.length / limit);

      if (currentPage > totalPages) currentPage = 1;

      const start = (currentPage - 1) * limit;
      const end = start + limit;

      // Hide all, then show filtered + paginated
      cards.forEach((c) => c.style.display = 'none');
      filtered.forEach((c, i) => {
        c.style.display = (i >= start && i < end) ? '' : 'none';
      });

      // Results count
      resultsCount.textContent = `Showing ${Math.min(end, filtered.length)} of ${filtered.length} airlines`;

      // Empty state
      emptyState.classList.toggle('hidden', filtered.length > 0);
      grid.classList.toggle('hidden', filtered.length === 0);

      // Pagination
      renderPagination(totalPages);
    }

    function renderPagination(totalPages: number) {
      if (totalPages <= 1) {
        pagination.innerHTML = '';
        return;
      }

      let html = '';
      const btnClass = 'px-3 py-1.5 rounded-lg text-sm font-medium transition-all duration-150 border';
      const activeStyle = 'background:var(--color-ink);color:var(--color-canvas);border-color:var(--color-ink)';
      const normalStyle = 'background:var(--color-canvas);color:var(--color-body);border-color:var(--color-hairline)';

      // Prev
      if (currentPage > 1) {
        html += `<button class="${btnClass}" style="${normalStyle}" data-page="${currentPage - 1}">← Prev</button>`;
      }

      // Page numbers
      for (let i = 1; i <= totalPages; i++) {
        if (totalPages > 7 && i > 2 && i < totalPages - 1 && Math.abs(i - currentPage) > 1) {
          if (i === 3 || i === totalPages - 2) html += `<span class="px-1 text-sm" style="color:var(--color-mute)">…</span>`;
          continue;
        }
        html += `<button class="${btnClass}" style="${i === currentPage ? activeStyle : normalStyle}" data-page="${i}">${i}</button>`;
      }

      // Next
      if (currentPage < totalPages) {
        html += `<button class="${btnClass}" style="${normalStyle}" data-page="${currentPage + 1}">Next →</button>`;
      }

      pagination.innerHTML = html;

      // Bind events
      pagination.querySelectorAll('[data-page]').forEach((btn) => {
        btn.addEventListener('click', () => {
          currentPage = parseInt((btn as HTMLElement).dataset.page!);
          render();
          grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    }

    // Event listeners
    searchInput.addEventListener('input', () => { currentPage = 1; render(); });
    regionFilter.addEventListener('change', () => { currentPage = 1; render(); });
    allianceFilter.addEventListener('change', () => { currentPage = 1; render(); });
    perPage.addEventListener('change', () => { currentPage = 1; render(); });

    render();
  }

  initAirlineFilters();
  document.addEventListener('astro:page-load', initAirlineFilters);
</script>
