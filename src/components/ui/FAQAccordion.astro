---
interface FAQ {
  question: string;
  answer: string;
}
interface Props {
  faqs: FAQ[];
  class?: string;
}
const { faqs, class: className = '' } = Astro.props;
---

<div class={`divide-y ${className}`} style="border-color:var(--color-hairline)">
  {faqs.map((faq, i) => (
    <div class="faq-item" data-faq-index={i}>
      <button
        class="w-full flex items-center justify-between gap-4 py-4 text-start cursor-pointer"
        aria-expanded="false"
        aria-controls={`faq-answer-${i}`}
        id={`faq-question-${i}`}
        style="background:none;border:none;padding-inline:0"
      >
        <span class="text-sm font-medium" style="color:var(--color-ink)">{faq.question}</span>
        <svg
          class="faq-chevron w-4 h-4 flex-shrink-0 transition-transform duration-200"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          aria-hidden="true"
          style="color:var(--color-mute)"
        >
          <path d="M4 6l4 4 4-4"/>
        </svg>
      </button>
      <div
        id={`faq-answer-${i}`}
        role="region"
        aria-labelledby={`faq-question-${i}`}
        class="faq-answer overflow-hidden"
        style="max-height:0;transition:max-height 0.25s ease"
      >
        <p class="text-sm pb-4 leading-relaxed" style="color:var(--color-body)">{faq.answer}</p>
      </div>
    </div>
  ))}
</div>

<script>
  function initFAQ() {
    document.querySelectorAll<HTMLElement>('.faq-item').forEach((item) => {
      const btn = item.querySelector('button');
      const answer = item.querySelector<HTMLElement>('.faq-answer');
      const chevron = item.querySelector<SVGElement>('.faq-chevron');
      if (!btn || !answer) return;

      btn.addEventListener('click', () => {
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        // Close all others
        document.querySelectorAll('.faq-item').forEach((other) => {
          const otherBtn = other.querySelector('button');
          const otherAnswer = other.querySelector<HTMLElement>('.faq-answer');
          const otherChevron = other.querySelector<SVGElement>('.faq-chevron');
          if (otherBtn && otherAnswer && other !== item) {
            otherBtn.setAttribute('aria-expanded', 'false');
            otherAnswer.style.maxHeight = '0';
            if (otherChevron) otherChevron.style.transform = '';
          }
        });

        if (isOpen) {
          btn.setAttribute('aria-expanded', 'false');
          answer.style.maxHeight = '0';
          if (chevron) chevron.style.transform = '';
        } else {
          btn.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight = answer.scrollHeight + 'px';
          if (chevron) chevron.style.transform = 'rotate(180deg)';
        }
      });
    });
  }

  initFAQ();
  document.addEventListener('astro:page-load', initFAQ);
</script>
