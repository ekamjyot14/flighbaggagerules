---
import ThemeToggle from './ThemeToggle.astro';
import { getLocaleFromUrl, getSegmentPath, createTranslator, loadTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/config';

const locale = getLocaleFromUrl(Astro.url) as Locale;
const translations = await loadTranslations(locale);
const t = createTranslator(translations);

const currentPath = Astro.url.pathname;

// Navigation with dropdown menus
const navItems = [
  {
    label: 'Airlines',
    href: getSegmentPath(locale, 'airlines'),
    dropdown: [
      { label: 'All Airlines', href: getSegmentPath(locale, 'airlines'), icon: '✈️' },
      { label: 'Delta Air Lines', href: getSegmentPath(locale, 'airlines', 'delta-air-lines'), icon: '🇺🇸' },
      { label: 'United Airlines', href: getSegmentPath(locale, 'airlines', 'united-airlines'), icon: '🇺🇸' },
      { label: 'American Airlines', href: getSegmentPath(locale, 'airlines', 'american-airlines'), icon: '🇺🇸' },
      { label: 'Southwest Airlines', href: getSegmentPath(locale, 'airlines', 'southwest-airlines'), icon: '🇺🇸' },
      { label: 'Emirates', href: getSegmentPath(locale, 'airlines', 'emirates'), icon: '🇦🇪' },
      { label: 'British Airways', href: getSegmentPath(locale, 'airlines', 'british-airways'), icon: '🇬🇧' },
    ],
  },
  {
    label: 'Items',
    href: getSegmentPath(locale, 'items'),
    dropdown: [
      { label: 'All Items', href: getSegmentPath(locale, 'items'), icon: '📦' },
      { label: 'Power Bank', href: getSegmentPath(locale, 'items', 'power-bank'), icon: '🔋' },
      { label: 'Laptop', href: getSegmentPath(locale, 'items', 'laptop'), icon: '💻' },
      { label: 'Medications', href: getSegmentPath(locale, 'items', 'medications'), icon: '💊' },
      { label: 'Lighter', href: getSegmentPath(locale, 'items', 'lighter'), icon: '🔥' },
      { label: 'Alcohol', href: getSegmentPath(locale, 'items', 'alcohol'), icon: '🍷' },
      { label: 'Vape', href: getSegmentPath(locale, 'items', 'vape'), icon: '💨' },
    ],
  },
  {
    label: 'Compare',
    href: getSegmentPath(locale, 'compare'),
    dropdown: null,
  },
  {
    label: 'Blog',
    href: getSegmentPath(locale, 'blog'),
    dropdown: null,
  },
  {
    label: 'About',
    href: '/about',
    dropdown: null,
  },
  {
    label: 'Contact',
    href: '/contact',
    dropdown: null,
  },
];
---

<header
  id="site-nav"
  class="fixed top-0 inset-x-0 z-40 border-b transition-all duration-200"
  style="height:64px;background:color-mix(in srgb,var(--color-canvas) 92%,transparent);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-color:var(--color-hairline)"
  role="banner"
>
  <div class="container-page h-full flex items-center gap-4">
    <!-- Mobile hamburger (left side) -->
    <button
      id="mobile-menu-btn"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="flex md:hidden items-center justify-center w-9 h-9 rounded-lg border transition-colors duration-150"
      style="border-color:var(--color-hairline);background:var(--color-canvas);color:var(--color-ink)"
    >
      <svg id="hamburger-icon" class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
        <line x1="2" y1="5" x2="14" y2="5"/><line x1="2" y1="8" x2="14" y2="8"/><line x1="2" y1="11" x2="14" y2="11"/>
      </svg>
      <svg id="close-icon" class="w-4 h-4 hidden" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="3" x2="13" y2="13"/><line x1="13" y1="3" x2="3" y2="13"/>
      </svg>
    </button>

    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-2.5 flex-shrink-0 no-underline"
      style="color:var(--color-ink)"
      aria-label="FlightBaggageRules.com — Home"
    >
      <img src="/favicon-96x96.png" alt="" class="w-8 h-8 rounded-lg" aria-hidden="true" />
      <span class="hidden sm:inline text-sm font-bold tracking-tight">FlightBaggageRules</span>
    </a>

    <!-- Desktop Nav Links with Dropdowns -->
    <nav class="hidden md:flex items-center gap-0.5 flex-1 ms-4" aria-label="Main navigation">
      {navItems.map((item) => {
        const isActive = currentPath === item.href || currentPath.startsWith(item.href + '/');
        return (
          <div class="nav-dropdown-container relative group">
            <a
              href={item.href}
              class="nav-link flex items-center gap-1 px-3 py-2 rounded-lg text-sm transition-all duration-150 no-underline"
              style={isActive
                ? 'color:var(--color-ink);background:var(--color-canvas-soft-2);font-weight:600'
                : 'color:var(--color-body)'}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
              {item.dropdown && (
                <svg class="w-3 h-3 opacity-50 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
                  <path d="M6 8L2 4h8L6 8z"/>
                </svg>
              )}
            </a>
            {item.dropdown && (
              <div class="nav-dropdown absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <div class="w-56 rounded-xl border p-1.5 shadow-lg" style="background:var(--color-canvas);border-color:var(--color-hairline);box-shadow:0 20px 40px rgba(0,0,0,0.12)">
                  {item.dropdown.map((link) => (
                    <a
                      href={link.href}
                      class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-sm no-underline transition-all duration-100 hover:bg-[var(--color-canvas-soft)]"
                      style="color:var(--color-body)"
                    >
                      <span class="text-base w-5 text-center flex-shrink-0" aria-hidden="true">{link.icon}</span>
                      <span>{link.label}</span>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        );
      })}
    </nav>

    <!-- Right side controls -->
    <div class="flex items-center gap-3 ms-auto">
      <!-- Quick action button -->
      <a
        href="/check"
        class="hidden md:flex items-center gap-2 px-3.5 h-8 rounded-lg text-xs font-semibold no-underline transition-all duration-200 hover:opacity-80 hover:scale-[1.02] active:scale-[0.98]"
        style="background:var(--color-ink);color:var(--color-canvas)"
      >
        <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M13 3L6 13l-3-3"/>
        </svg>
        Check Rules
      </a>

      <ThemeToggle />
    </div>
  </div>
</header>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  role="dialog"
  aria-label="Navigation menu"
  aria-modal="true"
  class="fixed inset-0 z-30 hidden md:hidden"
>
  <!-- Backdrop -->
  <div id="mobile-menu-backdrop" class="absolute inset-0" style="background:rgba(0,0,0,0.4)"></div>
  <!-- Panel sliding from left -->
  <div
    id="mobile-menu-panel"
    class="absolute top-0 left-0 bottom-0 w-72 overflow-y-auto"
    style="background:var(--color-canvas);box-shadow:4px 0 24px rgba(0,0,0,0.12)"
  >
    <div class="pt-20 px-6 pb-8 h-full">
      <nav class="flex flex-col gap-1" aria-label="Mobile navigation">
        {navItems.map((item) => {
          const isActive = currentPath === item.href || currentPath.startsWith(item.href + '/');
          return (
            <a
              href={item.href}
              class="px-4 py-3 rounded-lg text-base transition-colors duration-150 no-underline"
              style={isActive
                ? 'color:var(--color-ink);background:var(--color-canvas-soft-2);font-weight:500'
                : 'color:var(--color-body)'}
              data-mobile-nav-link
            >
              {item.label}
            </a>
          );
        })}
        <!-- Check Rules link in mobile -->
        <a
          href="/check"
          class="px-4 py-3 rounded-lg text-base font-medium transition-colors duration-150 no-underline mt-2"
          style="color:var(--color-ink);background:var(--color-canvas-soft)"
          data-mobile-nav-link
        >
          ✓ Check Rules
        </a>
      </nav>
    </div>
  </div>
</div>

<!-- Spacer so content starts below fixed nav -->
<div style="height:64px" aria-hidden="true"></div>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const backdrop = document.getElementById('mobile-menu-backdrop');
    const hamburger = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');
    const navLinks = document.querySelectorAll('[data-mobile-nav-link]');
    if (!btn || !menu) return;

    let isOpen = false;

    function openMenu() {
      isOpen = true;
      menu.classList.remove('hidden');
      hamburger?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      isOpen = false;
      menu.classList.add('hidden');
      hamburger?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    btn.addEventListener('click', () => (isOpen ? closeMenu() : openMenu()));
    backdrop?.addEventListener('click', closeMenu);
    navLinks.forEach((link) => link.addEventListener('click', closeMenu));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen) closeMenu(); });
  }

  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
</script>
