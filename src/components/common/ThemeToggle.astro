---
// ThemeToggle — visible toggle switch for dark/light mode
---
<button
  id="theme-toggle"
  aria-label="Toggle theme"
  title="Toggle theme"
  class="relative flex items-center w-14 h-7 rounded-full border transition-colors duration-200 cursor-pointer p-0.5"
  style="border-color:var(--color-hairline);background:var(--color-canvas-soft)"
>
  <!-- Track icons -->
  <span class="absolute left-1.5 top-1/2 -translate-y-1/2 text-xs pointer-events-none" aria-hidden="true">☀️</span>
  <span class="absolute right-1.5 top-1/2 -translate-y-1/2 text-xs pointer-events-none" aria-hidden="true">🌙</span>
  <!-- Thumb -->
  <span
    id="theme-toggle-thumb"
    class="relative w-5 h-5 rounded-full shadow-sm transition-transform duration-200"
    style="background:var(--color-ink);transform:translateX(0)"
  ></span>
</button>

<script>
  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    const thumb = document.getElementById('theme-toggle-thumb');
    if (!btn || !thumb) return;

    function getIsDark(): boolean {
      const stored = localStorage.getItem('fbr-theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      return stored === 'dark' || (!stored && prefersDark);
    }

    function applyTheme(isDark: boolean) {
      document.documentElement.classList.toggle('dark', isDark);
      // Move thumb: left (light) or right (dark)
      thumb!.style.transform = isDark ? 'translateX(28px)' : 'translateX(0)';
      btn!.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
    }

    function toggleTheme() {
      const isDark = getIsDark();
      const next = !isDark;
      localStorage.setItem('fbr-theme', next ? 'dark' : 'light');
      applyTheme(next);
    }

    // Init
    applyTheme(getIsDark());
    btn.addEventListener('click', toggleTheme);

    // Handle bfcache (back/forward nav) — re-sync thumb
    window.addEventListener('pageshow', (e: PageTransitionEvent) => {
      if (e.persisted) applyTheme(getIsDark());
    });

    // Listen for system preference changes
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
      const stored = localStorage.getItem('fbr-theme');
      if (!stored) applyTheme(window.matchMedia('(prefers-color-scheme: dark)').matches);
    });
  }

  initThemeToggle();
  document.addEventListener('astro:page-load', initThemeToggle);
</script>
