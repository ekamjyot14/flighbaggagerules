---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="flex items-center gap-1 text-sm flex-wrap">
  {items.map((item, i) => (
    <span class="flex items-center gap-1">
      {i > 0 && (
        <svg class="w-3 h-3 flex-shrink-0" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true" style="color:var(--color-mute)">
          <path d="M4 2l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
      )}
      {item.href && i < items.length - 1 ? (
        <a
          href={item.href}
          class="no-underline transition-colors duration-150 hover:opacity-80"
          style="color:var(--color-body)"
        >
          {item.label}
        </a>
      ) : (
        <span
          aria-current={i === items.length - 1 ? 'page' : undefined}
          style={i === items.length - 1 ? 'color:var(--color-ink);font-weight:500' : 'color:var(--color-body)'}
        >
          {item.label}
        </span>
      )}
    </span>
  ))}
</nav>
