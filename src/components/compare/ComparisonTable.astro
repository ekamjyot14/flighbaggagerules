---
interface Row {
  label: string;
  values: string[];
}

interface Props {
  headers: string[];
  rows: Row[];
  class?: string;
}

const { headers, rows, class: className } = Astro.props;
---

<div class:list={['overflow-x-auto rounded-xl border', className]} style="border-color:var(--color-hairline)">
  <table class="w-full text-sm" style="border-collapse:collapse">
    <thead>
      <tr style="border-bottom:1px solid var(--color-hairline)">
        {headers.map((header, i) => (
          <th
            scope={i === 0 ? 'col' : 'col'}
            class="px-4 py-3 text-left font-medium"
            style={`color:var(--color-ink);background:var(--color-canvas-soft);${i > 0 ? 'text-align:center' : ''}`}
          >
            {header}
          </th>
        ))}
      </tr>
    </thead>
    <tbody>
      {rows.map((row, rowIdx) => (
        <tr
          style={`border-bottom:1px solid var(--color-hairline);background:${rowIdx % 2 === 0 ? 'var(--color-canvas)' : 'var(--color-canvas-soft)'}`}
        >
          <td class="px-4 py-3 font-medium" style="color:var(--color-ink)">{row.label}</td>
          {row.values.map((val) => (
            <td class="px-4 py-3 text-center" style="color:var(--color-body)">{val}</td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>
