---
interface Props {
  name: string;
  slug: string;
  iata?: string;
  country: string;
  region?: string;
  alliance?: string;
  logo?: string;
  lastUpdated?: string;
  href: string;
}

const { name, iata, country, region, alliance, logo, lastUpdated, href } = Astro.props;

function getInitials(name: string) {
  return name
    .split(' ')
    .slice(0, 2)
    .map((w) => w[0])
    .join('')
    .toUpperCase();
}
---

<a
  href={href}
  class="group flex flex-col gap-4 p-5 rounded-xl border transition-all duration-200 no-underline hover:-translate-y-0.5 h-full"
  style="background:var(--color-canvas);border-color:var(--color-hairline);box-shadow:var(--shadow-card)"
  aria-label={`${name} baggage rules`}
>
  <!-- Logo / Initials -->
  <div class="flex items-start justify-between gap-3">
    <div
      class="w-11 h-11 rounded-lg flex items-center justify-center flex-shrink-0 overflow-hidden border"
      style="background:white;border-color:var(--color-hairline)"
    >
      {logo ? (
        <img
          src={logo}
          alt={`${name} logo`}
          width="44"
          height="44"
          class="w-full h-full object-contain p-1"
          loading="lazy"
        />
      ) : (
        <span class="text-sm font-bold" style="color:var(--color-body);font-family:var(--font-mono)">
          {getInitials(name)}
        </span>
      )}
    </div>
    {alliance && (
      <span
        class="px-2 py-0.5 rounded text-xs font-medium border"
        style="color:var(--color-mute);border-color:var(--color-hairline);background:var(--color-canvas-soft)"
      >
        {alliance}
      </span>
    )}
  </div>

  <!-- Info -->
  <div class="flex-1 min-w-0">
    <h3
      class="text-sm font-semibold mb-1 truncate transition-colors duration-150"
      style="color:var(--color-ink)"
    >
      {name}
    </h3>
    <p class="text-xs truncate" style="color:var(--color-mute)">
      {country}{region ? ` · ${region}` : ''}
    </p>
  </div>

  <!-- Footer -->
  <div class="flex items-center justify-between pt-3 border-t mt-auto" style="border-color:var(--color-hairline)">
    <span class="text-xs font-medium px-2 py-0.5 rounded" style="color:var(--color-body);background:var(--color-canvas-soft)">
      View Rules →
    </span>
    <svg
      class="w-4 h-4 transition-transform duration-150 group-hover:translate-x-0.5"
      viewBox="0 0 16 16"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      style="color:var(--color-mute)"
      aria-hidden="true"
    >
      <path d="M3 8h10M9 4l4 4-4 4"/>
    </svg>
  </div>
</a>
